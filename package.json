{
  "name": "@dancingmusic/dance-plugin-mineradio",
  "version": "1.1.0",
  "description": "Mineradio stage lyric, particle cover, gesture camera, and 3D playlist shelf plugin for DancingMusic.",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target es2020 --no-splitting --dts --clean",
    "postbuild": "node scripts/strip-trailing-whitespace.mjs dist/index.js",
    "dev": "tsup src/index.ts --format esm --target es2020 --no-splitting --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "dancingmusic",
    "dance-plugin",
    "mineradio",
    "lyrics",
    "particles",
    "visualizer",
    "three"
  ],
  "author": "DancingMusic",
  "license": "GPL-3.0",
  "peerDependencies": {
    "@dancingmusic/plugin-sdk": "^1.1.0",
    "three": "^0.181.2"
  },
  "dependencies": {
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@dancingmusic/plugin-sdk": "file:../DancingMusic/submodules/DancingPluginSdk",
    "@types/node": "^24.10.1",
    "@types/three": "^0.185.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
